# Server
PORT=4000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000

# Database
# Local: use localhost. Docker Compose: use service name "db"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dnews_africa?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/dnews_africa?schema=public"

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# API Docs
ENABLE_API_DOCS=true